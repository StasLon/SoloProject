--- !u!114 &522171269
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 522171267}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f08edcc6a87db624684d3a717b8c40ba, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 361297017}
  fullText1: "\u042D\u0442\u043E\u0442 \u043C\u043E\u043D\u0441\u0442\u0440 \u0445\u043E\u0434\u0438\u0442
    \u0437\u0430 \u043C\u043D\u043E\u0439 \u043F\u043E \u043F\u044F\u0442\u0430\u043C."
  fullText2: "\u042F \u0434\u043E\u043B\u0436\u0435\u043D \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443... \u0434\u0430\u0436\u0435
    \u0435\u0441\u043B\u0438 \u044D\u0442\u043E \u0431\u0443\u0434\u0435\u0442 \u0441\u0442\u043E\u0438\u0442\u044C
    \u043C\u043D\u0435 \u0436\u0438\u0437\u043D\u0438."
  fullText3: "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
    \u043D\u0435 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u0435\u043C\u0443
    \u0432 \u0433\u043B\u0430\u0437\u0430. \u0427\u0443\u0432\u0441\u0432\u0442\u0443\u044E
    - \u043C\u043E\u0451 \u0441\u0435\u0440\u0434\u0446\u0435 \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0438\u0442
    \u044D\u0442\u043E\u0433\u043E."
  delay: 0.05
