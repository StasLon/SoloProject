    \u0434\u0430\u0432\u044F\u0449\u0438\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u043D\u0430 \u0442\u0432\u043E\u044E \u0441\u043F\u0438\u043D\u0443."
  - "\u0413\u043E\u043D: \u0425\u0432\u0430\u0442\u0438\u0442. \u042F \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u044E
    \u0442\u0435\u0431\u044F. \u0422\u044B \u0437\u0430 \u043C\u043E\u0435\u0439
    \u0441\u043F\u0438\u043D\u043E\u0439 \u0441 \u043D\u0430\u0447\u0430\u043B\u0430
    \u043F\u0443\u0442\u0438. \u041A\u0442\u043E \u0442\u044B?"
  - "\u0422\u0451\u043C\u043D\u044B\u0439 \u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:
    \u041D\u0435 \u0441\u0442\u0440\u0430\u043D\u043D\u043E \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u0442\u044C
    \u0441\u043E \u043C\u043D\u043E\u0439, \u0433\u043B\u044F\u0434\u044F \u0432
    \u0434\u0440\u0443\u0433\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443?"
  - "\u0413\u043E\u043D: \u0422\u044B \u043D\u0435 \u043E\u0442\u0432\u0435\u0442\u0438\u043B
    \u043D\u0430 \u0432\u043E\u043F\u0440\u043E\u0441."
  - "\u0422\u0451\u043C\u043D\u044B\u0439 \u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:
    \u042F? \u0421\u043A\u0430\u0436\u0435\u043C \u0442\u0430\u043A\u2026 \u044F
    \u0440\u044F\u0434\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u0442\u044B \u043D\u0435
    \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u043B\u0441\u044F."
  - "\u0413\u043E\u043D: \u0417\u0430\u0431\u043B\u0443\u0434\u0438\u0442\u044C\u0441\u044F
    \u0437\u0434\u0435\u0441\u044C? \u042D\u0442\u043E \u043D\u0435 \u043B\u0435\u0441,
    \u0447\u0442\u043E\u0431\u044B \u0432 \u043D\u0451\u043C \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u0442\u044C\u0441\u044F.
    \u0423 \u043C\u0435\u043D\u044F \u043D\u0435\u0442 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
    \u043D\u0430 \u044D\u0442\u0438 \u0438\u0433\u0440\u044B, \u044F \u0437\u0434\u0435\u0441\u044C
    \u0447\u0442\u043E\u0431\u044B \u0432\u0441\u0451 \u043F\u043E\u0447\u0438\u043D\u0438\u0442\u044C."
  - "\u0422\u0451\u043C\u043D\u044B\u0439 \u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:
    \u041E\u0447\u0435\u0440\u0435\u0434\u043D\u0430\u044F \u043F\u043E\u043F\u044B\u0442\u043A\u0430
    \u043F\u043E\u0447\u0438\u043D\u0438\u0442\u044C \u0442\u043E, \u0447\u0435\u0433\u043E
    \u043D\u0435 \u0437\u043D\u0430\u0435\u0448\u044C? \u0417\u0430\u0447\u0435\u043C
    \u0421\u0443\u0434\u044C\u044F \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442
    \u0441\u043B\u0435\u043F\u043E\u0433\u043E \u043A\u043E\u0442\u0451\u043D\u043A\u0430
    \u0432 \u0442\u044C\u043C\u0443?"
  - "\u0413\u043E\u043D: \u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E
    \u0442\u043E\u043B\u044C\u043A\u043E \u044F \u043C\u043E\u0433\u0443."
  - "\u0422\u0451\u043C\u043D\u044B\u0439 \u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:
    \u041D\u0435\u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u043E, \u043F\u043E\u0442\u043E\u043C\u0443
    \u0447\u0442\u043E \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435\u0442 \u043A\u043E\u0433\u043E."
  - "\u0422\u044B \u043D\u0435 \u043C\u043E\u0436\u0435\u0448\u044C \u043D\u0430\u0439\u0442\u0438
    \u0441\u043B\u043E\u0432, \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0432\u0435\u0442\u0438\u0442\u044C
    \u0435\u043C\u0443 \u0438 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0448\u044C
    \u0440\u0435\u0448\u0435\u043D\u0438\u0435 \u043F\u0440\u043E\u043C\u043E\u043B\u0447\u0430\u0442\u044C."
  - "\u0422\u0451\u043C\u043D\u044B\u0439 \u041F\u0430\u0441\u0441\u0430\u0436\u0438\u0440:
    \u0418\u0434\u0438... \u042F \u043D\u0438\u043A\u0443\u0434\u0430 \u043D\u0435
    \u0434\u0435\u043D\u0443\u0441\u044C. \u0412\u043E\u043F\u0440\u043E\u0441 \u0442\u043E\u043B\u044C\u043A\u043E
    \u0432 \u0442\u043E\u043C, \u043A\u043E\u0433\u0434\u0430 \u0442\u044B \u0440\u0435\u0448\u0438\u0448\u044C\u0441\u044F
    \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C."
  - "\u0422\u044B \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0448\u044C, \u0447\u0442\u043E
    \u0442\u0432\u043E\u0451 \u0441\u0435\u0440\u0434\u0446\u0435 \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0438\u0442,
    \u0435\u0441\u043B\u0438 \u0442\u044B \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u0448\u044C
    \u0435\u043C\u0443 \u0432 \u0433\u043B\u0430\u0437\u0430 \u0438 \u0440\u0435\u0448\u0430\u0435\u0448\u044C
    \u043D\u0435 \u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C \u043D\u0430 \u043D\u0435\u0433\u043E
    \u0447\u0435\u0433\u043E \u0431\u044B \u044D\u0442\u043E \u043D\u0435 \u0441\u0442\u043E\u0438\u043B\u043E"
  textSpeed: 0.01
  typingAudio: {fileID: 190406209}
  characterAnimator: {fileID: 1785889301}
  maxTalkingDistance: 5
